{
  "definitions": [
    {
      "title": "Media Grid",
      "id": "media-grid",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Media Grid",
              "filter": "media-grid",
              "model": "media-grid"
            }
          }
        }
      }
    },
    {
      "title": "Media Grid Cell",
      "id": "media-grid-cell",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Media Grid Cell",
              "model": "media-grid-cell"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "media-grid",
      "fields": [
        {
          "component": "text",
          "valueType": "string",
          "name": "heading",
          "label": "Encabezado de la sección (H2)",
          "description": "Opcional. Deja vacío si el grid no lleva título."
        }
      ]
    },
    {
      "id": "media-grid-cell",
      "fields": [
        {
          "component": "select",
          "valueType": "string",
          "name": "cell",
          "label": "Tipo de celda",
          "required": true,
          "options": [
            { "name": "Imagen", "value": "image" },
            { "name": "Texto (editorial)", "value": "text" }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "title",
          "label": "Título / Caption",
          "description": "Para celdas de texto: título del panel. Para imagen: caption superpuesta."
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "body",
          "label": "Cuerpo (solo celda de texto)"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "ctaText",
          "label": "Texto del CTA (solo celda de texto)"
        },
        {
          "component": "aem-content",
          "name": "cta",
          "label": "Enlace del CTA (solo celda de texto)"
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Imagen (solo celda de imagen)",
          "multi": false
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Texto alternativo de la imagen"
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "Enlace destino (solo celda de imagen)"
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "rowSpan",
          "label": "Alto (nº de filas)",
          "options": [
            { "name": "1 fila", "value": "1" },
            { "name": "2 filas", "value": "2" }
          ]
        },
        {
          "component": "select",
          "valueType": "string",
          "name": "colSpan",
          "label": "Ancho (nº de columnas)",
          "options": [
            { "name": "1 columna", "value": "1" },
            { "name": "2 columnas", "value": "2" }
          ]
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "media-grid",
      "components": ["media-grid-cell"]
    }
  ]
}
