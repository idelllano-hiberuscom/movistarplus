{
  "definitions": [
    {
      "title": "Plan Selector",
      "id": "plan-selector",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Plan Selector",
              "filter": "plan-selector",
              "model": "plan-selector"
            }
          }
        }
      }
    },
    {
      "title": "Plan Selector Item",
      "id": "plan-selector-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Plan Selector Item",
              "model": "plan-selector-item"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "plan-selector",
      "fields": [
        {
          "component": "text",
          "valueType": "string",
          "name": "heading",
          "label": "Encabezado de la sección (H2)",
          "required": true
        }
      ]
    },
    {
      "id": "plan-selector-item",
      "fields": [
        {
          "component": "text",
          "valueType": "string",
          "name": "title",
          "label": "Nombre del plan (ej. 'Movistar Plus mensual')",
          "required": true
        },
        {
          "component": "richtext",
          "name": "features",
          "label": "Lista de beneficios (ul/li)",
          "valueType": "string",
          "required": true
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "priceInteger",
          "label": "Parte entera del precio (ej. '9')",
          "required": true
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "priceDecimals",
          "label": "Decimales y moneda (ej. ',99€'). Vacío para planes gratuitos."
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "period",
          "label": "Periodo de facturación (ej. 'MES', 'AÑO', 'Sin coste')",
          "required": true
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "taxLabel",
          "label": "Texto fiscal pequeño (ej. 'Imp. incl.')"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "priceFootnote",
          "label": "Texto bajo el precio (ej. 'Precio final al mes')"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "ctaText",
          "label": "Texto del botón (ej. 'SUSCRIBIRME')",
          "required": true
        },
        {
          "component": "aem-content",
          "name": "cta",
          "label": "URL destino del botón",
          "required": true
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "badge",
          "label": "Badge esquina superior (ej. 'Tarifa estrella'). Vacío = sin badge.",
          "multi": false
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "badgeAlt",
          "label": "Texto alternativo del badge"
        },
        {
          "component": "boolean",
          "name": "featured",
          "label": "Marcar como tarjeta destacada (aplica estilo dark + borde naranja)",
          "valueType": "boolean"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "plan-selector",
      "components": [
        "plan-selector-item"
      ]
    }
  ]
}
