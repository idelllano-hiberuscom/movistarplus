{
  "definitions": [
    {
      "title": "Footer",
      "id": "footer",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Footer",
              "model": "footer"
            }
          }
        }
      }
    },
    {
      "title": "Footer Column",
      "id": "footer-column",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Footer Column",
              "model": "footer-column"
            }
          }
        }
      }
    },
    {
      "title": "Footer Link",
      "id": "footer-link",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Footer Link",
              "model": "footer-link"
            }
          }
        }
      }
    },
    {
      "title": "Footer Social",
      "id": "footer-social",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Footer Social",
              "model": "footer-social"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "footer",
      "fields": [
        {
          "component": "reference",
          "valueType": "string",
          "name": "logo",
          "label": "Logo del footer",
          "multi": false
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "logoAlt",
          "label": "Texto alternativo del logo",
          "value": "Movistar Plus+"
        },
        {
          "component": "aem-content",
          "name": "logoLink",
          "label": "Enlace del logo (normalmente la home)"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "copyright",
          "label": "Texto de copyright",
          "description": "Puedes usar el placeholder {year} para el año dinámico.",
          "value": "© Telefónica de España, S.A.U. {year}"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "socialHeading",
          "label": "Título de la zona de redes",
          "value": "Síguenos en redes"
        }
      ]
    },
    {
      "id": "footer-column",
      "fields": [
        {
          "component": "text",
          "valueType": "string",
          "name": "heading",
          "label": "Título de la columna",
          "required": true
        }
      ]
    },
    {
      "id": "footer-link",
      "fields": [
        {
          "component": "text",
          "valueType": "string",
          "name": "label",
          "label": "Etiqueta visible",
          "required": true
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "URL destino",
          "required": true
        }
      ]
    },
    {
      "id": "footer-social",
      "fields": [
        {
          "component": "select",
          "valueType": "string",
          "name": "network",
          "label": "Red social",
          "required": true,
          "options": [
            { "name": "Facebook", "value": "facebook" },
            { "name": "Twitter / X", "value": "twitter" },
            { "name": "Instagram", "value": "instagram" },
            { "name": "YouTube", "value": "youtube" },
            { "name": "TikTok", "value": "tiktok" },
            { "name": "LinkedIn", "value": "linkedin" }
          ]
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "URL destino de la red social",
          "required": true
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "ariaLabel",
          "label": "Texto accesible (aria-label)",
          "description": "Si se deja vacío, se autogenera como \"Síguenos en {red}\"."
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "footer-columns",
      "components": [
        "footer-column"
      ]
    },
    {
      "id": "footer-column-links",
      "components": [
        "footer-link"
      ]
    },
    {
      "id": "footer-legal-links",
      "components": [
        "footer-link"
      ]
    },
    {
      "id": "footer-social-links",
      "components": [
        "footer-social"
      ]
    }
  ]
}
